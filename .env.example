# ─── BASE DE DATOS ───────────────────────────────────────
# Railway lo genera automáticamente al conectar PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── JWT ─────────────────────────────────────────────────
# Generá uno random: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_secreto_largo

# ─── SERVIDOR ────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── WHATSAPP (WPPConnect) ───────────────────────────────
# URL interna de Railway (mismo proyecto):
WPPCONNECT_URL=http://server-cli.railway.internal:21465
# URL pública (si WPPConnect está en otro proyecto o dominio externo):
# WPPCONNECT_URL=https://server-cli-production-xxxx.up.railway.app
WPPCONNECT_SECRET_KEY=filoCRM_secret

# ─── EMAIL (Nodemailer / SendGrid) ───────────────────────
# Opción A — SMTP genérico (Gmail, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
SMTP_FROM=FILO CRM <tu@email.com>

# Opción B — SendGrid (comentar las de arriba y usar esta)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ─── MERCADOPAGO ─────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
# URL base de tu app (para webhooks de MP)
APP_URL=https://filocrm-production.up.railway.app
